# =============================================================================
# Vault Environment Config
# Copy to .env.local and fill in values
# In CI/CD: set these as pipeline environment variables
# =============================================================================

VAULT_PROJECT=kafka-template
VAULT_ENV=local
VAULT_CONTAINER=vault-template
VAULT_ADDR=http://127.0.0.1:8200
VAULT_DOMAIN=localhost
AWS_REGION=us-east-1

# Database engine — mysql | postgresql
VAULT_DB_ENGINE=mysql
VAULT_DB_HOST=mysql
VAULT_DB_PORT=3306
VAULT_DB_ROOT_USER=root

# KMS auto-unseal key ID (production only — leave empty for local)
# Obtain with: aws kms describe-key --key-id alias/vault-unseal --query KeyMetadata.KeyId
VAULT_KMS_KEY_ID=
